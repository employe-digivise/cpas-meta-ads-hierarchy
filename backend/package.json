{
  "name": "cpas-meta-ads-backend",
  "version": "1.0.0",
  "description": "Backend service untuk Meta Ads data ingestion - menggantikan workflow n8n yang kompleks",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "cp '../Modal & Deployment/execution/.env' dist/.env",
    "start": "node dist/index.js",
    "dev": "ts-node '../Modal & Deployment/execution/index.ts'",
    "dev:watch": "ts-node-dev --respawn '../Modal & Deployment/execution/index.ts'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0"
  }
}
