# Copy file ini ke .env lalu isi nilainya.
# .env di-gitignore — jangan pernah di-commit.

# Bearer token untuk endpoint Modal (nilai ada di Modal Secret: api-auth-token)
API_AUTH_TOKEN=

# Optional — override endpoint default (kalau redeploy ke account Modal lain)
# CPAS_ENDPOINT=https://<user>--cpas-meta-ads-fetch-meta-ads.modal.run
