# Copy file ini ke .env lalu isi nilainya.
# .env di-gitignore — jangan pernah di-commit.

# ── Auth ────────────────────────────────────────────────────────
# Bearer token untuk endpoint POST /fetch_meta_ads
API_AUTH_TOKEN=

# ── Meta Ads ────────────────────────────────────────────────────
# Long-lived access token Meta (rotate setiap ~60 hari)
META_ACCESS_TOKEN=

# ── Webhooks ────────────────────────────────────────────────────
# n8n webhook tujuan untuk cron harian
N8N_WEBHOOK_URL=

# Optional — webhook alert (Slack/Discord/generic). Kalau kosong, alert di-log saja.
ALERT_WEBHOOK_URL=

# ── Server (VPS) ────────────────────────────────────────────────
# Host & port untuk uvicorn. Default 0.0.0.0:9005.
HOST=0.0.0.0
PORT=9005

# ── Optional client config ──────────────────────────────────────
# CPAS_ENDPOINT=http://31.97.222.83:9005
